# ═══ Sisaket Robotics 2026 — Environment Variables ═══
# คัดลอกไฟล์นี้ไปเป็น .env แล้วแก้ค่าให้ตรงกับ environment ของคุณ
# ห้าม commit ไฟล์ .env เข้า git เด็ดขาด

# ─── Server ──────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# ─── MongoDB ─────────────────────────────────────────────
# ใช้ Atlas / DO Managed MongoDB:
#   mongodb+srv://USER:PASS@cluster.mongodb.net/sisaket_robotics?retryWrites=true&w=majority
# หรือใช้ local/docker-compose:
#   mongodb://mongodb:27017/sisaket_robotics
MONGODB_URI=mongodb://localhost:27017/sisaket_robotics

# ─── JWT Auth ────────────────────────────────────────────
# ใช้คำสุ่มยาว ≥32 ตัวอักษร (openssl rand -hex 32)
JWT_SECRET=change_this_to_a_long_random_string_min_32_chars
JWT_EXPIRES_IN=24h

# ─── CORS ────────────────────────────────────────────────
# URL ของ frontend (ใช้ '*' สำหรับ dev; production ควรตั้ง origin ที่ถูกต้อง)
FRONTEND_URL=https://your-app.ondigitalocean.app

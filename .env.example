# ═══════════════════════════════════════════════════════════════
#  Sisaket Robotics 2026 — Environment Variables (TEMPLATE)
# ───────────────────────────────────────────────────────────────
#  ใช้ไฟล์นี้เป็น reference ว่ามี env var ตัวไหนบ้าง
#
#  ลำดับการโหลด (หลัง override ก่อน):
#    1. .env.<NODE_ENV>       (committed — dev/prod defaults)
#    2. .env.<NODE_ENV>.local (gitignored — personal override)
#    3. .env                  (gitignored — legacy fallback)
#    4. .env.local            (gitignored — personal override ทุก env)
#
#  Production (DigitalOcean): ค่า secret ใส่ใน Dashboard → Settings → Env Vars
# ═══════════════════════════════════════════════════════════════

# ─── Runtime ─────────────────────────────────────────────
NODE_ENV=development        # development | production | test
PORT=5000

# ─── MongoDB ─────────────────────────────────────────────
# Local (docker-compose):   mongodb://mongodb:27017/sisaket_robotics
# Atlas free tier:          mongodb+srv://USER:PASS@cluster.mongodb.net/sisaket_robotics
MONGODB_URI=mongodb://localhost:27017/sisaket_robotics

# ─── JWT Auth ────────────────────────────────────────────
# สร้างด้วย: openssl rand -hex 32
JWT_SECRET=change_this_to_a_long_random_string_min_32_chars
JWT_EXPIRES_IN=24h

# ─── CORS ────────────────────────────────────────────────
# Dev ใช้ '*' ได้ (same-origin) — Prod ควรระบุ origin ที่ถูกต้อง
FRONTEND_URL=*

# ─── Logging ─────────────────────────────────────────────
LOG_LEVEL=info              # debug | info | warn | error
